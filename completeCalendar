def is_leap(year):
    """Returns True if the year is a leap year, False otherwise."""
    # Rule: Divisible by 400 OR (divisible by 4 and NOT 100)
    return (year % 400 == 0) or (year % 4 == 0 and year % 100 != 0)

def print_calendar(start_day, total_days):
    # 0: Mon, 1: Tue, 2: Wed, 3: Thu, 4: Fri, 5: Sat, 6: Sun
    header = "Mon Tue Wed Thu Fri Sat Sun"
    print(header)

    # Step 1: Print the leading empty spaces
    # Each day in our format occupies 4 spaces (3 for number/space + 1 gap)
    for i in range(start_day):
        print("    ", end="")

    # Step 2: Print the actual days
    for day in range(1, total_days + 1):
        # Format the number to be 3 characters wide
        print(f"{day:3}", end=" ")

        # Step 3: Check if we need a new line
        # If (offset + current day) is a multiple of 7, the row is full
        if (start_day + day) % 7 == 0:
            print()
    
    # Final newline just for clean output
    print()

# --- BUILDING ON TOP ---

# 1. Setup Data
month_days = [31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31]

# 2. Get Input
month = int(input("Enter month (1-12): "))
year = int(input("Enter year: "))

# 3. Update February if it's a leap year
if is_leap(year):
    month_days[1] = 29

# 4. Calculate the Start Day
# We calculate total days passed since Year 1, Month 1, Day 1 (which was a Monday/0)
total_passed_days = 0

# Add days for every year from year 1 up to (but not including) the target year
for y in range(1, year):
    if is_leap(y):
        total_passed_days += 366
    else:
        total_passed_days += 365

# Add days for every month in the target year up to the target month
for m in range(month - 1):
    total_passed_days += month_days[m]

# The remainder tells us the weekday (0=Mon, 1=Tue, etc.)
calculated_start_day = total_passed_days % 7

# 5. Execute the Engine
print(f"\n--- Calendar for {month}/{year} ---")
print_calendar(calculated_start_day, month_days[month - 1])
